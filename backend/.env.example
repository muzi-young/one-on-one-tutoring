# 服务端口
PORT=3000

# JWT
JWT_SECRET=please_change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# 数据库：sqlite (默认，免安装) 或 mysql
DB_DIALECT=sqlite
DB_STORAGE=db.sqlite

# 仅当 DB_DIALECT=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tutoring
DB_USER=root
DB_PASSWORD=

# 腾讯会议 OpenAPI（真实接入时填写）
TC_MEET_APPID=
TC_MEET_SECRET_ID=
TC_MEET_SECRET_KEY=
